@{
    ViewData["Title"] = "Chia sẻ tài liệu mới";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Tải tài liệu mới lên hệ thống</h4>
        </div>
        <div class="card-body">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                <div class="text-danger mb-3">@Html.ValidationSummary(true)</div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Tiêu đề hiển thị</label>
                    <input type="text" name="title" class="form-control" placeholder="Ví dụ: Đồ án mẫu Lập trình Web" />
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Mô tả tài liệu</label>
                    <textarea name="description" class="form-control" rows="3" placeholder="Nhập mô tả ngắn gọn về nội dung file..."></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label font-weight-bold">Chọn File tài liệu (PDF, Word, Zip, Hình ảnh...)</label>
                    <input type="file" name="uploadFile" class="form-control" required />
                    <small class="text-muted">Lưu ý: Không tải lên các file định dạng phần mềm (.exe, .msi).</small>
                </div>

                <div class="mb-4">
                    <label class="form-label font-weight-bold">Hạn lưu trữ (tự động xóa nếu không có lượt tải mới)</label>
                    <select name="expirationDays" class="form-select rounded-3">
                        <option value="7">7 ngày (Tối ưu bộ nhớ)</option>
                        <option value="15">15 ngày</option>
                        <option value="30" selected>30 ngày (Mặc định)</option>
                        <option value="90">90 ngày (Lưu trữ dài hạn)</option>
                        <option value="0">Vĩnh viễn (Không tự động xóa)</option>
                    </select>
                    <small class="text-muted">Tệp tin sẽ tự động bị xóa khỏi máy chủ và cơ sở dữ liệu nếu không phát sinh lượt tải xuống nào trong thời gian này.</small>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                    <button type="submit" class="btn btn-success px-4">Bắt đầu tải lên</button>
                </div>
            </form>
        </div>
    </div>
</div>